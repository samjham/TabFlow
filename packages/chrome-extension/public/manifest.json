{
  "manifest_version": 3,
  "name": "TabFlow",
  "version": "0.1.0",
  "description": "Organize your tabs into workspaces. Save, restore, and sync across devices.",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "activeTab",
    "sidePanel",
    "nativeMessaging",
    "alarms",
    "system.memory"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["youtube-time-tracker.js"],
      "run_at": "document_idle"
    }
  ]
}
