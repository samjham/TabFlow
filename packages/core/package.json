{
  "name": "@tabflow/core",
  "version": "0.1.0",
  "description": "Core TypeScript library for tab management, workspace organization, and session persistence",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./models": {
      "types": "./dist/models/types.d.ts",
      "default": "./dist/models/types.js"
    },
    "./storage": {
      "types": "./dist/storage/StorageAdapter.d.ts",
      "default": "./dist/storage/StorageAdapter.js"
    },
    "./workspace": {
      "types": "./dist/workspace/WorkspaceEngine.d.ts",
      "default": "./dist/workspace/WorkspaceEngine.js"
    },
    "./sync": {
      "types": "./dist/sync/SyncClient.d.ts",
      "default": "./dist/sync/SyncClient.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "tab-manager",
    "browser",
    "workspace",
    "session",
    "persistence"
  ],
  "author": "TabFlow Team",
  "license": "MIT"
}
