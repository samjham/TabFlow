{
  "name": "@tabflow/browser-extension",
  "version": "0.1.0",
  "description": "Cross-browser extension for TabFlow - Organize your tabs into workspaces",
  "type": "module",
  "scripts": {
    "dev": "cross-env TARGET=chrome vite",
    "build": "npm run build:chrome && npm run build:firefox",
    "build:chrome": "cross-env TARGET=chrome vite build",
    "build:firefox": "cross-env TARGET=firefox vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "generate-icons": "node scripts/generate-icons.js",
    "test": "vitest run --config tests/unit.vitest.config.ts",
    "test:smoke": "vitest run --config tests/vitest.config.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.102.1",
    "@tabflow/core": "*",
    "dexie": "^4.4.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.246",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "cross-env": "^7.0.3",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
